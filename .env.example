# Copy to .env.local and fill in secrets.
# Each Chroma Cloud database has its own API key — run:
#   chroma db connect <database-name> --env-vars

# --- Local dev (default) ---
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
CHROMA_MODE=local
CHROMA_PATH=.rag/chroma
CHROMA_COLLECTION=agentic_architectures

# --- Cloud prod (.env.cloud-prod) ---
# CHROMA_MODE=cloud
# CHROMA_API_KEY=ck-...
# CHROMA_TENANT=...
# CHROMA_DATABASE=agenticArchitecturesProd
# CHROMA_COLLECTION=agentic_architectures

# --- Cloud dev (.env.cloud-dev) ---
# CHROMA_MODE=cloud
# CHROMA_DATABASE=agenticArchitecturesDev
